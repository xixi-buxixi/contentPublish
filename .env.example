# Pulse Distro local configuration template.
# Copy to .env and fill private values locally. Do not commit real .env files.

SERVER_PORT=8080
WS_ENDPOINT=/ws/pipeline

H2_DB_PATH=./data/h2/pulse-distro
H2_DB_USERNAME=sa
H2_DB_PASSWORD=

MEDIA_STORAGE_ROOT=./data/media
APP_PUBLIC_BASE_URL=http://localhost:8080

LANGCHAIN4J_API_KEY=
LANGCHAIN4J_BASE_URL=https://api.deepseek.com
LANGCHAIN4J_MODEL_NAME=deepseek-v4-flash
ADAPT_TIMEOUT_SECONDS=30
ADAPT_EXECUTOR_CORE_SIZE=4
ADAPT_EXECUTOR_MAX_SIZE=8
ADAPT_EXECUTOR_QUEUE_CAPACITY=64

PIPELINE_EVENT_RETENTION_MS=1800000
EVENT_CLEANUP_INTERVAL_MS=60000

CODEX_HOOK_OUTPUT=brief
CODEX_HOOK_MAX_CHARS=6000
